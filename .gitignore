# ============================================================
# QazVelo-Engine — .gitignore
#
# Project layout:
#   backend/          FastAPI / Python backend
#   artifacts/qazvelo/    React + Vite frontend
#   artifacts/api-server/ Express proxy
#   lib/              Shared TypeScript packages
#   scripts/          Dev + CI shell scripts
# ============================================================


# ── Python: bytecode & import caches ─────────────────────────
__pycache__/
*.py[cod]
*$py.class


# ── Python: virtual environments ─────────────────────────────
.venv/
venv/
ENV/
env/


# ── Replit: managed Python package store ─────────────────────
# Equivalent to a virtual environment — regenerated by Replit,
# never committed.
.pythonlibs/


# ── Python: test & lint caches ───────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/


# ── Python: test coverage ────────────────────────────────────
.coverage
coverage.xml
htmlcov/


# ── Dev secret key (FastAPI JWT signing) ─────────────────────
# Auto-generated for local dev only. In production, set the
# SECRET_KEY environment variable instead.
backend/.dev_secret_key


# ── SQLite / database cache files ────────────────────────────
# Created at runtime by yfinance (cookies.db, tkr-tz.db) and
# similar libraries. Never committed.
*.db
*.sqlite
*.sqlite3


# ── Node / pnpm ──────────────────────────────────────────────
node_modules/
.pnpm-store/

# Stray npm lockfile — this project uses pnpm exclusively.
# package-lock.json should not exist at the root.
package-lock.json


# ── Build outputs ────────────────────────────────────────────
# Covers artifacts/api-server/dist/ and any other compiled output.
dist/
build/
.build/
.next/
out/

# Python compiled extensions
*.so
*.egg
*.egg-info/


# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ── Environment & secrets ────────────────────────────────────
# .env.example IS committed (documents required variables).
# All other .env variants are secrets and must never be committed.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key


# ── Editors & OS artifacts ───────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~
.DS_Store
Thumbs.db


# ── Cursor ───────────────────────────────────────────────────
.cursor/
.cursorignore
.cursorrules
.cursorrules.md
.cursorrules.txt
.cursorrules.yml
.cursorrules.yaml
