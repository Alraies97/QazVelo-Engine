# Copy this file to .env.local and adjust values for your environment
# If your backend is served at http://localhost:8000 and routes are prefixed with /api/v1 (default), you can omit these.
# If your backend is proxied or served on the same origin, set BASE_PATH instead of BASE_URL.

# Absolute base URL for API (overrides BASE_PATH)
# NEXT_PUBLIC_API_BASE_URL="http://localhost:8000/api/v1"

# When frontend and backend share origin, set this path (defaults to /api/v1)
NEXT_PUBLIC_API_BASE_PATH="/api/v1"
