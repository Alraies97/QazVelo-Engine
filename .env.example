# =============================================================================
# QazVelo-Engine — Environment Variable Reference
# =============================================================================
# Copy this file to .env (never commit .env) and fill in the values.
# All variables have sensible defaults for local development; only SECRET_KEY
# and DATABASE_URL are required to run the backend successfully.
#
# Quick start (local, no Docker):
#   cp .env.example .env
#   pnpm dev          # starts frontend + proxy + backend concurrently
#
# Quick start (Docker):
#   cp .env.example .env   # set SECRET_KEY + DATABASE_URL at minimum
#   docker compose up
# =============================================================================


# =============================================================================
# SHARED
# =============================================================================

# Runtime environment.
# "development" → fakeredis fallback, auto-generates SECRET_KEY, relaxed CORS.
# "production"  → real Redis required, SECRET_KEY must be set, strict validation.
ENVIRONMENT=development


# =============================================================================
# FRONTEND  (Vite / React — artifacts/qazvelo)
# =============================================================================

# TCP port the Vite dev server binds to.
# Must be 5000 on Replit (preview pane requirement).  Free to change locally.
PORT=5000

# URL base-path for the React app.  Use / unless deploying under a sub-path.
BASE_PATH=/

# FastAPI origin the Vite dev-server proxy forwards /api/v1/* to.
# Local:  http://localhost:8000
# Docker: http://backend:8000
BACKEND_URL=http://localhost:8000

# Optional: override the axios base URL used by the React client.
# Leave unset to use the relative /api/v1 path (works through the Vite proxy).
# VITE_API_BASE_URL=http://localhost:8000/api/v1
# VITE_API_BASE_PATH=/api/v1


# =============================================================================
# EXPRESS API PROXY  (artifacts/api-server)
# =============================================================================

# TCP port the Express proxy listens on.
PROXY_PORT=8080

# FastAPI origin the Express proxy forwards /api/v1/* to.
# Must match the backend's HOST:PORT.
# Local:  http://127.0.0.1:8000
# Docker: http://backend:8000
FASTAPI_URL=http://127.0.0.1:8000

# Log verbosity for pino.  Options: trace | debug | info | warn | error | fatal
LOG_LEVEL=info


# =============================================================================
# FASTAPI BACKEND  (backend/)
# =============================================================================

# TCP port uvicorn binds to.
PORT=8000

# Bind address.  Use 0.0.0.0 for Docker / container deployments.
HOST=0.0.0.0

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in production.  Minimum 32 characters.  Generate with:
#   python -c "import secrets; print(secrets.token_hex(48))"
# In development, run.py auto-generates and persists a key to .dev_secret_key.
SECRET_KEY=

# JWT algorithm and token lifetimes.
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL async connection string.
# Replit:  set automatically via the built-in PostgreSQL integration.
# Local:   postgresql+asyncpg://postgres:password@localhost:5432/qazvelo_db
# Docker:  postgresql+asyncpg://postgres:password@postgres:5432/qazvelo_db
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/qazvelo_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection string.
# Absent or unreachable in development → auto-falls back to in-process fakeredis.
# Local Docker:  redis://localhost:6379
# Docker Compose: redis://redis:6379
# Upstash (prod): rediss://:password@hostname:6380
REDIS_URL=redis://localhost:6379

# ── Kafka (optional — graceful degradation when absent) ───────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── CORS / Trusted Hosts ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  * allows all (default for dev).
ALLOWED_ORIGINS=*
ALLOWED_HOSTS=*

# ── Binance Integration (paper-trading mode by default) ───────────────────────
# Leave empty to stay in paper-trading mode — no real funds at risk.
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# true → testnet.binance.vision  |  false → api.binance.com (real funds!)
BINANCE_TESTNET=true

# Master kill-switch for live order routing.  Must be explicitly set to true.
ENABLE_BINANCE_LIVE_TRADING=false
